<style>
  /* ══════════ CUSTOM PROPERTIES ══════════ */
  .sp-baq {
    --sp-azul: #192640;
    --sp-azul-light: #1e3055;
    --sp-blanco: #FFFFFF;
    --sp-naranja: #F2541B;
    --sp-amarillo: #FFD23F;
    --sp-verde: #06D6A0;
    --sp-magenta: #E63996;
    --sp-gris-claro: #F5F5F7;
    --sp-texto: #333333;
    --sp-whatsapp: #25D366;
    --sp-radius: 16px;
    --sp-shadow: 0 8px 30px rgba(25, 38, 64, 0.12);
    --sp-transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    --sp-gradient-carnaval: linear-gradient(135deg, var(--sp-naranja), var(--sp-magenta), var(--sp-amarillo), var(--sp-verde));

    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--sp-texto);
    line-height: 1.6;
    overflow-x: hidden;
  }

  .sp-baq *, .sp-baq *::before, .sp-baq *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ══════════ ANIMACIONES GLOBALES ══════════ */
  @keyframes sp-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-12px) rotate(2deg); }
    66% { transform: translateY(6px) rotate(-1deg); }
  }

  @keyframes sp-gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes sp-confetti-fall {
    0% { top: -8%; opacity: 0; transform: translateX(0) rotate(0deg) scale(1); }
    10% { opacity: 0.9; }
    50% { transform: translateX(50px) rotate(360deg) scale(0.8); }
    90% { opacity: 0.5; }
    100% { top: 108%; opacity: 0; transform: translateX(-30px) rotate(720deg) scale(0.6); }
  }

  @keyframes sp-pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(242, 84, 27, 0.4); }
    50% { transform: scale(1.05); box-shadow: 0 0 0 15px rgba(242, 84, 27, 0); }
  }

  @keyframes sp-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes sp-shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  @keyframes sp-border-dance {
    0%, 100% { background-position: 0% 50%; }
    25% { background-position: 100% 0%; }
    50% { background-position: 100% 100%; }
    75% { background-position: 0% 100%; }
  }

  @keyframes sp-count-bar {
    from { width: 0; }
  }

  @keyframes sp-wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(3deg); }
    75% { transform: rotate(-3deg); }
  }

  @keyframes sp-slide-up {
    from { opacity: 0; transform: translateY(60px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes sp-slide-left {
    from { opacity: 0; transform: translateX(80px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes sp-scale-in {
    from { opacity: 0; transform: scale(0.8); }
    to { opacity: 1; transform: scale(1); }
  }

  /* ══════════ HERO ══════════ */
  .sp-baq-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--sp-azul);
  }

  .sp-baq-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .sp-baq-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sp-baq-hero__bg-mobile { display: none; }

  .sp-baq-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(242, 84, 27, 0.25) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(230, 57, 150, 0.15) 0%, transparent 50%),
      linear-gradient(160deg, rgba(25, 38, 64, 0.92) 0%, rgba(25, 38, 64, 0.7) 40%, rgba(25, 38, 64, 0.85) 100%);
  }

  /* Confetti hero */
  .sp-baq-confetti {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    overflow: hidden;
  }

  .sp-baq-confetti i {
    position: absolute;
    top: -10%;
    opacity: 0;
    animation: sp-confetti-fall linear infinite;
  }

  .sp-baq-confetti i:nth-child(1) { left: 3%; width: 14px; height: 8px; background: var(--sp-amarillo); animation-duration: 5.5s; animation-delay: 0s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(2) { left: 10%; width: 8px; height: 8px; background: var(--sp-magenta); animation-duration: 7s; animation-delay: 0.8s; border-radius: 50%; }
  .sp-baq-confetti i:nth-child(3) { left: 18%; width: 12px; height: 6px; background: var(--sp-verde); animation-duration: 6s; animation-delay: 1.5s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(4) { left: 26%; width: 10px; height: 10px; background: var(--sp-naranja); animation-duration: 8s; animation-delay: 0.3s; border-radius: 50%; }
  .sp-baq-confetti i:nth-child(5) { left: 34%; width: 16px; height: 6px; background: var(--sp-amarillo); animation-duration: 5s; animation-delay: 2s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(6) { left: 42%; width: 6px; height: 14px; background: var(--sp-magenta); animation-duration: 7.5s; animation-delay: 1s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(7) { left: 50%; width: 10px; height: 10px; background: var(--sp-verde); animation-duration: 6.5s; animation-delay: 3s; border-radius: 50%; }
  .sp-baq-confetti i:nth-child(8) { left: 58%; width: 14px; height: 5px; background: var(--sp-naranja); animation-duration: 5.8s; animation-delay: 0.5s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(9) { left: 66%; width: 8px; height: 12px; background: var(--sp-amarillo); animation-duration: 7.2s; animation-delay: 1.8s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(10) { left: 74%; width: 12px; height: 12px; background: var(--sp-magenta); animation-duration: 6.3s; animation-delay: 2.5s; border-radius: 50%; }
  .sp-baq-confetti i:nth-child(11) { left: 82%; width: 10px; height: 6px; background: var(--sp-verde); animation-duration: 5.2s; animation-delay: 0.2s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(12) { left: 90%; width: 8px; height: 14px; background: var(--sp-naranja); animation-duration: 8.5s; animation-delay: 1.3s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(13) { left: 7%; width: 6px; height: 6px; background: var(--sp-amarillo); animation-duration: 9s; animation-delay: 3.5s; border-radius: 50%; }
  .sp-baq-confetti i:nth-child(14) { left: 47%; width: 14px; height: 4px; background: var(--sp-magenta); animation-duration: 6.8s; animation-delay: 4s; border-radius: 2px; }
  .sp-baq-confetti i:nth-child(15) { left: 95%; width: 10px; height: 10px; background: var(--sp-verde); animation-duration: 7.8s; animation-delay: 0.7s; border-radius: 50%; }

  /* Formas flotantes decorativas en hero */
  .sp-baq-hero__shapes {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .sp-baq-hero__shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.06;
    animation: sp-float 8s ease-in-out infinite;
  }

  .sp-baq-hero__shape:nth-child(1) { width: 300px; height: 300px; background: var(--sp-naranja); top: -5%; right: -5%; animation-delay: 0s; }
  .sp-baq-hero__shape:nth-child(2) { width: 200px; height: 200px; background: var(--sp-magenta); bottom: 10%; left: -3%; animation-delay: 2s; }
  .sp-baq-hero__shape:nth-child(3) { width: 150px; height: 150px; background: var(--sp-amarillo); top: 30%; right: 10%; animation-delay: 4s; }
  .sp-baq-hero__shape:nth-child(4) { width: 100px; height: 100px; background: var(--sp-verde); bottom: 20%; right: 20%; animation-delay: 1s; }

  .sp-baq-hero__content {
    position: relative;
    z-index: 5;
    text-align: center;
    padding: 2rem;
    max-width: 900px;
  }

  .sp-baq-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, var(--sp-naranja), var(--sp-magenta));
    color: var(--sp-blanco);
    padding: 0.5rem 1.5rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    animation: sp-pulse 2.5s ease-in-out infinite;
  }

  .sp-baq-hero__title {
    font-size: clamp(3rem, 9vw, 6rem);
    font-weight: 900;
    color: var(--sp-blanco);
    line-height: 1;
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .sp-baq-hero__title span {
    display: block;
    background: linear-gradient(90deg, var(--sp-naranja), var(--sp-amarillo), var(--sp-naranja));
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: sp-gradient-shift 4s linear infinite;
  }

  .sp-baq-hero__subtitle {
    font-size: clamp(1.1rem, 3vw, 1.6rem);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2.5rem;
    font-weight: 300;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .sp-baq-hero__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .sp-baq-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--sp-naranja);
    color: var(--sp-blanco);
    padding: 1.1rem 2.8rem;
    border-radius: 50px;
    font-size: 1.15rem;
    font-weight: 700;
    text-decoration: none;
    transition: var(--sp-transition);
    border: 2px solid var(--sp-naranja);
    position: relative;
    overflow: hidden;
  }

  .sp-baq-hero__cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: 0.6s;
  }

  .sp-baq-hero__cta:hover::before {
    left: 100%;
  }

  .sp-baq-hero__cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(242, 84, 27, 0.5);
  }

  .sp-baq-hero__cta--secondary {
    background: transparent;
    border-color: rgba(255,255,255,0.5);
    color: var(--sp-blanco);
  }

  .sp-baq-hero__cta--secondary:hover {
    border-color: var(--sp-blanco);
    background: rgba(255,255,255,0.1);
    box-shadow: 0 10px 30px rgba(255,255,255,0.15);
  }

  /* Scroll indicator */
  .sp-baq-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.5);
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    animation: sp-float 3s ease-in-out infinite;
  }

  .sp-baq-hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
  }

  /* ══════════ MARQUEE TICKER ══════════ */
  .sp-baq-marquee {
    background: linear-gradient(90deg, var(--sp-naranja), var(--sp-magenta), var(--sp-amarillo), var(--sp-verde), var(--sp-naranja));
    background-size: 200% auto;
    animation: sp-gradient-shift 6s linear infinite;
    padding: 0.9rem 0;
    overflow: hidden;
    white-space: nowrap;
    position: relative;
  }

  .sp-baq-marquee__track {
    display: inline-flex;
    animation: sp-marquee 25s linear infinite;
  }

  .sp-baq-marquee__item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0 2rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--sp-blanco);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .sp-baq-marquee__dot {
    width: 6px;
    height: 6px;
    background: var(--sp-blanco);
    border-radius: 50%;
    opacity: 0.6;
  }

  /* ══════════ SECTION COMMON ══════════ */
  .sp-baq-section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .sp-baq-section-header__label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--sp-naranja);
    margin-bottom: 0.8rem;
    position: relative;
    padding: 0 1rem;
  }

  .sp-baq-section-header__label::before,
  .sp-baq-section-header__label::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 30px;
    height: 2px;
    background: var(--sp-naranja);
    opacity: 0.4;
  }

  .sp-baq-section-header__label::before { right: 100%; }
  .sp-baq-section-header__label::after { left: 100%; }

  .sp-baq-section-header__title {
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    font-weight: 900;
    color: var(--sp-azul);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .sp-baq-section-header__title--light {
    color: var(--sp-blanco);
  }

  .sp-baq-section-header__sub {
    font-size: 1.15rem;
    color: #666;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .sp-baq-section-header__sub--light {
    color: rgba(255,255,255,0.7);
  }

  /* ══════════ CATEGORIAS ══════════ */
  .sp-baq-categorias {
    padding: 5rem 1.5rem;
    background: var(--sp-gris-claro);
    position: relative;
    overflow: hidden;
  }

  /* Patron carnavalero de fondo */
  .sp-baq-categorias::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    pointer-events: none;
    background-image:
      radial-gradient(circle 20px at 10% 15%, var(--sp-magenta) 30%, transparent 31%),
      radial-gradient(circle 12px at 8% 11%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 12px at 12% 11%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 12px at 10% 8%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 12px at 10% 20%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 20px at 40% 45%, var(--sp-naranja) 30%, transparent 31%),
      radial-gradient(circle 12px at 38% 41%, var(--sp-verde) 30%, transparent 31%),
      radial-gradient(circle 12px at 42% 41%, var(--sp-verde) 30%, transparent 31%),
      radial-gradient(circle 20px at 70% 20%, var(--sp-verde) 30%, transparent 31%),
      radial-gradient(circle 12px at 68% 16%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 12px at 72% 16%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 20px at 90% 60%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 12px at 88% 56%, var(--sp-magenta) 30%, transparent 31%),
      radial-gradient(circle 12px at 92% 56%, var(--sp-magenta) 30%, transparent 31%),
      radial-gradient(circle 20px at 25% 78%, var(--sp-naranja) 30%, transparent 31%),
      radial-gradient(circle 12px at 23% 74%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 12px at 27% 74%, var(--sp-amarillo) 30%, transparent 31%),
      radial-gradient(circle 20px at 80% 85%, var(--sp-magenta) 30%, transparent 31%),
      radial-gradient(circle 12px at 78% 81%, var(--sp-verde) 30%, transparent 31%),
      radial-gradient(circle 12px at 82% 81%, var(--sp-verde) 30%, transparent 31%);
    z-index: 0;
  }

  .sp-baq-categorias > * { position: relative; z-index: 1; }

  .sp-baq-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.8rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .sp-baq-card {
    background: var(--sp-blanco);
    border-radius: var(--sp-radius);
    overflow: hidden;
    text-decoration: none;
    color: var(--sp-texto);
    box-shadow: var(--sp-shadow);
    transition: var(--sp-transition);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* Borde gradiente animado */
  .sp-baq-card::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: calc(var(--sp-radius) + 2px);
    background: var(--sp-gradient-carnaval);
    background-size: 300% 300%;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.4s ease;
    animation: sp-border-dance 4s ease infinite;
  }

  .sp-baq-card:hover::before {
    opacity: 1;
  }

  .sp-baq-card:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 0 20px 50px rgba(25, 38, 64, 0.2);
  }

  .sp-baq-card__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #e9e9e9;
    position: relative;
  }

  .sp-baq-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    display: block;
  }

  .sp-baq-card:hover .sp-baq-card__img img {
    transform: scale(1.12);
  }

  /* Overlay al hover */
  .sp-baq-card__img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(25, 38, 64, 0.6) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .sp-baq-card:hover .sp-baq-card__img::after {
    opacity: 1;
  }

  .sp-baq-card__name {
    padding: 1.2rem 1rem 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    text-align: center;
    color: var(--sp-azul);
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--sp-transition);
  }

  .sp-baq-card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.6rem 1rem 1.2rem;
    color: var(--sp-naranja);
    font-size: 0.85rem;
    font-weight: 700;
    transition: var(--sp-transition);
  }

  .sp-baq-card__arrow svg {
    transition: transform 0.3s ease;
  }

  .sp-baq-card:hover .sp-baq-card__arrow svg {
    transform: translateX(5px);
  }

  /* ══════════ PRODUCTO DESTACADO ══════════ */
  .sp-baq-producto {
    padding: 5rem 1.5rem;
    background: var(--sp-azul);
    position: relative;
    overflow: hidden;
  }

  .sp-baq-producto__bg-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background:
      repeating-linear-gradient(45deg, transparent, transparent 40px, var(--sp-naranja) 40px, var(--sp-naranja) 42px),
      repeating-linear-gradient(-45deg, transparent, transparent 40px, var(--sp-magenta) 40px, var(--sp-magenta) 42px);
    pointer-events: none;
  }

  .sp-baq-producto__wrapper {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .sp-baq-producto__visual {
    position: relative;
  }

  .sp-baq-producto__img-wrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
  }

  .sp-baq-producto__img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* Badge flotante sobre la imagen */
  .sp-baq-producto__float-badge {
    position: absolute;
    top: -15px;
    right: -15px;
    width: 90px;
    height: 90px;
    background: var(--sp-naranja);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--sp-blanco);
    font-weight: 800;
    font-size: 0.75rem;
    text-transform: uppercase;
    line-height: 1.2;
    animation: sp-float 4s ease-in-out infinite;
    box-shadow: 0 8px 25px rgba(242, 84, 27, 0.4);
    z-index: 2;
  }

  .sp-baq-producto__float-badge strong {
    font-size: 1.1rem;
  }

  /* Forma decorativa detras */
  .sp-baq-producto__deco {
    position: absolute;
    width: 120%;
    height: 120%;
    top: -10%;
    left: -10%;
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    background: linear-gradient(135deg, rgba(242, 84, 27, 0.1), rgba(230, 57, 150, 0.1));
    z-index: -1;
    animation: sp-wiggle 8s ease-in-out infinite;
  }

  .sp-baq-producto__info {
    color: var(--sp-blanco);
  }

